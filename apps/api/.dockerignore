# Build artifacts and dev-only files. Keeps the Docker build context lean
# and prevents accidental secret exposure (e.g. a stray .env).
.env
.env.*
!.env.example

# Local binary from `go build` outside Docker
tend-api

# Generated docs reproduce inside the image when needed; not required at runtime
docs/

# Test files don't need to be in the production image
*_test.go

# Empty placeholder files have no purpose in a built image
internal/*/.gitkeep

# VCS, IDE, OS noise
.git/
.gitignore
.vscode/
.idea/
.DS_Store

# Node / pnpm context (this is a Go module — no JS belongs here)
node_modules/
package.json

# Story-meta files (none expected here, but defensive)
*.md
