# Tend API environment variables.
# Copy to .env and fill in values for local development.
# Do not commit .env (it's gitignored).
#
# In Railway (staging + production), these are set via the project dashboard.
# DATABASE_URL is auto-provided by the Postgres add-on as `${{Postgres.DATABASE_URL}}`.

# PORT=8080
# DATABASE_URL=postgres://tend:tend@localhost:5432/tend?sslmode=disable
# GIN_MODE=release  # set in Railway envs only — keep debug locally
