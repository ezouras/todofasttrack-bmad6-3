# Tend mobile environment variables.
# Copy to .env and fill in values for local development.
# Expo exposes only EXPO_PUBLIC_-prefixed vars to the client bundle.
#
# Story 1.1 ships an empty scaffold. Future stories add the env vars they
# need (auth, billing, etc.). Don't list keys here until the story
# that uses them lands.

EXPO_PUBLIC_API_BASE_URL=http://localhost:8080
