# Tend web environment variables.
# Copy to .env (or .env.local) and fill in values for local development.
# Vite exposes only VITE_-prefixed vars to the client bundle.
#
# In production, all required vars are set in the Vercel project dashboard.
# `apps/web/src/lib/env.ts` will throw at startup if a required var is missing
# in a production build.

VITE_API_BASE_URL=http://localhost:8080
